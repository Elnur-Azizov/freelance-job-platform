@model List<dynamic>

@{
    ViewData["Title"] = "Ana Sayfa";
}

<div class="py-5">
    <!-- HERO -->
    <div class="p-5 rounded-4 border hero-box">
        <div class="row align-items-center g-4">
            <div class="col-md-7">
                <h1 class="display-6 fw-bold mb-3">
                    Freelance işlerini hızlıca bul,<br>
                    kolayca yönet</h1>
                <p class="text-muted mb-4">
                    İş ilanlarını keşfet, teklif ver ve sözleşmelerini tek panelden takip et.
                </p>

                <div class="d-flex gap-2 flex-wrap">
                    <a class="btn btn-dark" href="/Jobs">İlanlara Göz At</a>

                    @if (Context.Session.GetInt32("user_id") == null)
                    {
                        <button class="btn btn-success"
                                onclick="openAuthModal('login','/Jobs/Create'); return false;">
                            İş İlanı Oluştur
                        </button>
                    }
                    else
                    {
                        <a class="btn btn-success" href="/Jobs/Create">İş İlanı Oluştur</a>
                    }
                </div>
            </div>

            <div class="col-md-5">
                <div class="rounded-4 p-4 border bg-white">
                    <div class="small text-muted mb-2">İstatistik özeti</div>

                    <div class="d-flex justify-content-between py-2 border-bottom">
                        <div>Aktif İlan</div>
                        <div class="fw-bold">@ViewBag.ActiveJobs</div>
                    </div>

                    <div class="d-flex justify-content-between py-2 border-bottom">
                        <div>Toplam Başvuru</div>
                        <div class="fw-bold">@ViewBag.TotalApplications</div>
                    </div>

                    <div class="d-flex justify-content-between py-2 border-bottom">
                        <div>Aktif Sözleşme</div>
                        <div class="fw-bold">@ViewBag.ActiveContracts</div>
                    </div>

                    <div class="d-flex justify-content-between py-2">
                        <div>Kullanıcı</div>
                        <div class="fw-bold">@ViewBag.Users</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- LATEST JOBS -->
    <div class="d-flex justify-content-between align-items-center mt-5 mb-3">
        <h2 class="h4 m-0">Son Eklenen İlanlar</h2>
        <a class="text-decoration-none" href="/Jobs">Tümünü Gör →</a>
    </div>

    @if (Model == null || Model.Count == 0)
    {
        <div class="alert alert-info">Henüz ilan yok. İlk ilanı sen oluşturabilirsin.</div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var job in Model)
            {
                <div class="col-md-4">
                    <div class="border rounded-4 p-3 bg-white h-100 job-card">
                        <div class="fw-bold fs-5 mb-2">@job.title</div>
                        <div class="text-muted mb-3" style="min-height:44px;">
                            @(job.description?.ToString().Length > 70 ? job.description.ToString().Substring(0, 70) + "..." : job.description)
                        </div>

                        <div class="d-flex gap-2 flex-wrap mb-3">
                            <span class="badge text-bg-light border">Bütçe: @job.budget</span>
                            <span class="badge text-bg-light border">Süre: @job.requested_days gün</span>
                        </div>

                        <a class="btn btn-outline-dark btn-sm"
                           asp-controller="Jobs"
                           asp-action="Details"
                           asp-route-id="@job.job_id">
                            İlana Git
                        </a>
                    </div>
                </div>
            }
        </div>
    }
</div>