@model Freelance_System.Models.Job

@{
    ViewData["Title"] = "İlanı Düzenle";
}

<h2>İlanı Düzenle</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<form method="post" action="/Jobs/Edit/@Model.job_id" class="mt-3" style="max-width:700px;">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label class="form-label">Başlık</label>
        <input class="form-control" name="title" value="@Model.title" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Açıklama</label>
        <textarea class="form-control" name="description" rows="5">@Model.description</textarea>
    </div>

    <div class="mb-3">
        <label class="form-label">Bütçe</label>
        <input class="form-control" type="number" name="budget" min="1" value="@Model.budget" required />
    </div>

    <div class="mb-3">
        <label class="form-label">İstenen Süre (Gün)</label>
        <input class="form-control" type="number" name="requested_days" min="1" value="@Model.requested_days" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Durum</label>
        <select class="form-select" name="status">
            <option value="open" selected="@(Model.status == "open")">Açık</option>
            <option value="closed" selected="@(Model.status == "closed")">Kapalı</option>
        </select>
        <small class="text-muted">Kapalı yaparsan ilan listeden kaybolur ve başvuru alınmaz.</small>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-success">Kaydet</button>
        <a class="btn btn-secondary" href="/Jobs/Details/@Model.job_id">İptal</a>
    </div>
</form>